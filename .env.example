# Environment Configuration
# Copy this file to .env and fill in your API keys

# OpenRouter API Key (for AI matching)
# Get your key at: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# eBay API Key (optional, for production use)
# Get your key at: https://developer.ebay.com/
EBAY_API_KEY=your_ebay_api_key_here

# SerpAPI (recommended for Kleinanzeigen search - 250 free/month)
# Get your key at: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# Google Custom Search API (optional fallback)
# Get your API key at: https://console.cloud.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Google Custom Search Engine ID
# Create a search engine at: https://programmablesearchengine.google.com/
GOOGLE_CX=your_custom_search_engine_id_here
